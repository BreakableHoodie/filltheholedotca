PUBLIC_SUPABASE_URL=https://placeholder.supabase.co
PUBLIC_SUPABASE_ANON_KEY=placeholder_anon_key
SUPABASE_SERVICE_ROLE_KEY=placeholder_service_role_key
# Bearer token for legacy /api/admin/* endpoints (photo/pothole moderation).
# New admin UI uses session-based auth; this guards the older public API routes.
# Generate with: openssl rand -hex 32
ADMIN_SECRET=placeholder_admin_secret
SIGHTENGINE_API_USER=placeholder_sightengine_user
SIGHTENGINE_API_SECRET=placeholder_sightengine_secret
# Optional: SightEngine workflow ID for automated moderation decisions.
# Create a workflow at dashboard.sightengine.com/workflows, configure rules
# (nudity, offensive, etc.) and thresholds there. When set, the photos API
# uses /check-workflow.json (accept/reject); when absent, falls back to manual
# model scoring with MODERATION_THRESHOLD = 0.5.
SIGHTENGINE_WORKFLOW_ID=
# Random secret used to HMAC-SHA-256 IP addresses before storage.
# Generate with: openssl rand -hex 32
# Changing this invalidates all existing ip_hash deduplication records.
IP_HASH_SECRET=placeholder_ip_hash_secret
# 32-byte hex secret for signing admin CSRF tokens.
# Generate with: openssl rand -hex 32
ADMIN_SESSION_SECRET=placeholder_admin_session_secret
# 32-byte hex AES-GCM key for encrypting TOTP secrets at rest.
# Generate with: openssl rand -hex 32
# Changing this key invalidates all enrolled TOTP secrets in admin_users.
TOTP_ENCRYPTION_KEY=placeholder_totp_encryption_key
# One-time bootstrap secret for creating the first admin account at /admin/signup.
# Bootstrap is only allowed while admin_users is empty.
# Generate with: openssl rand -hex 32
ADMIN_BOOTSTRAP_SECRET=placeholder_admin_bootstrap_secret
# Pushover push notifications (optional — omit both to disable).
# Create an app at https://pushover.net/apps/build to get APP_TOKEN.
# Your user/group key is shown at https://pushover.net after login.
PUSHOVER_APP_TOKEN=
PUSHOVER_USER_KEY=
# Sentry error tracking (optional — omit to disable in local dev).
# Create a SvelteKit project at sentry.io to get your DSN.
# This is a PUBLIC_ variable — it is embedded in the browser bundle.
PUBLIC_SENTRY_DSN=
# Web Push (VAPID) keys for browser push notifications (optional — omit both to disable).
# Generate with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY is also exposed as PUBLIC_VAPID_PUBLIC_KEY for the browser subscription UI.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
PUBLIC_VAPID_PUBLIC_KEY=
# Disable API rate limiting in test/dev environments only (never set in production).
DISABLE_API_RATE_LIMIT=
